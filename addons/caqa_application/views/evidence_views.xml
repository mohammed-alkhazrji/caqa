<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- caqa.application.evidence List View -->
    <record id="view_caqa_application_evidence_tree" model="ir.ui.view">
        <field name="name">caqa.application.evidence.tree</field>
        <field name="model">caqa.application.evidence</field>
        <field name="arch" type="xml">
            <tree string="Evidence Items" decoration-danger="state=='missing'" decoration-info="state=='uploaded'" decoration-success="state=='approved'">
                <field name="application_id" invisible="context.get('default_application_id')"/>
                <field name="indicator_id"/>
                <field name="name"/>
                <field name="attachment_name" invisible="1"/>
                <field name="attachment" filename="attachment_name" widget="binary"/>
                <field name="state" widget="badge" 
                       decoration-danger="state=='missing'" 
                       decoration-info="state=='uploaded'" 
                       decoration-success="state=='approved'"/>
            </tree>
        </field>
    </record>

    <!-- caqa.application.evidence Form View -->
    <record id="view_caqa_application_evidence_form" model="ir.ui.view">
        <field name="name">caqa.application.evidence.form</field>
        <field name="model">caqa.application.evidence</field>
        <field name="arch" type="xml">
            <form string="Evidence Item">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="btn-success" invisible="state != 'uploaded'" groups="caqa_security.group_caqa_reviewer,caqa_security.group_caqa_accreditation_officer"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-danger" invisible="state not in ('uploaded', 'approved')" groups="caqa_security.group_caqa_reviewer,caqa_security.group_caqa_accreditation_officer"/>
                    <field name="state" widget="statusbar" statusbar_visible="missing,uploaded,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Faculty Resumes"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="application_id"/>
                            <field name="indicator_id" domain="[('subchapter_id.chapter_id.version_id', '=', context.get('default_standard_version_id', False))]"/>
                        </group>
                        <group>
                            <field name="attachment_name" invisible="1"/>
                            <field name="attachment" filename="attachment_name" widget="binary"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
