<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_application_tree" model="ir.ui.view">
        <field name="name">caqa.application.tree</field>
        <field name="model">caqa.application</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'approved'" decoration-warning="state == 'conditional_approved'" decoration-danger="state == 'rejected'">
                <field name="reference"/>
                <field name="institution_id"/>
                <field name="program_id"/>
                <field name="cycle_id"/>
                <field name="completion_rate" widget="progressbar"/>
                <field name="readiness_score" widget="progressbar"/>
                <field name="open_deficiency_count"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_application_search" model="ir.ui.view">
        <field name="name">caqa.application.search</field>
        <field name="model">caqa.application</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="institution_id"/>
                <field name="program_id"/>
                <field name="state"/>
<!--                <filter name="flt_open" string="Open Deficiencies" domain="[('open_deficiency_count', '&gt;', 0)]"/>-->
                <group expand="0" string="Group By">
                    <filter string="Institution" name="grp_institution" context="{'group_by': 'institution_id'}"/>
                    <filter string="State" name="grp_state" context="{'group_by': 'state'}"/>
                    <filter string="Cycle" name="grp_cycle" context="{'group_by': 'cycle_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_caqa_application_form" model="ir.ui.view">
        <field name="name">caqa.application.form</field>
        <field name="model">caqa.application</field>
        <field name="arch" type="xml">
            <form string="Accreditation Application">
                <header>
                    <button name="action_generate_structure" string="Generate Structure" type="object" invisible="state != 'draft'"/>
                    <button name="action_formal_intake" string="Formal Intake" type="object" invisible="state not in ('draft','in_progress')"/>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state not in ('draft','in_progress','need_more_information')"/>
                    <button name="action_under_initial_review" string="Initial Review" type="object" invisible="state not in ('submitted','resubmitted')"/>
                    <button name="action_need_more_information" string="Need More Information" type="object" invisible="state not in ('under_initial_review','under_evaluation')"/>
                    <button name="action_resubmit" string="Resubmit" type="object" invisible="state != 'need_more_information'"/>
                    <button name="action_under_evaluation" string="Under Evaluation" type="object" invisible="state not in ('under_initial_review','resubmitted')"/>
                    <button name="action_under_site_visit" string="Under Site Visit" type="object" invisible="state != 'under_evaluation'"/>
                    <button name="action_under_committee_review" string="Committee Review" type="object" invisible="state not in ('under_evaluation','under_site_visit')"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state != 'under_committee_review'"/>
                    <button name="action_conditional_approve" string="Conditional Approval" type="object" invisible="state != 'under_committee_review'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'under_committee_review'"/>
                    <button name="action_close" string="Close" type="object" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,submitted,under_initial_review,need_more_information,resubmitted,under_evaluation,under_site_visit,under_committee_review,approved,conditional_approved,rejected,appealed,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_indicators" type="object" class="oe_stat_button" icon="fa-sliders">
                            <field name="indicator_count" widget="statinfo" string="Indicators"/>
                        </button>
                        <button name="action_view_deficiencies" type="object" class="oe_stat_button" icon="fa-exclamation-circle">
                            <field name="deficiency_count" widget="statinfo" string="Deficiencies"/>
                        </button>
                        <button name="action_view_state_history" type="object" class="oe_stat_button" icon="fa-history">
                            <field name="open_deficiency_count" widget="statinfo" string="Open"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <div class="text-muted"><field name="reference" readonly="1"/></div>
                    </div>
                    <group>
                        <group>
                            <field name="institution_id"/>
                            <field name="program_id"/>
                            <field name="eligibility_id"/>
                            <field name="profile_id"/>
                            <field name="accreditation_type_id"/>
                        </group>
                        <group>
                            <field name="cycle_id"/>
                            <field name="standard_version_id"/>
                            <field name="formal_intake_user_id"/>
                            <field name="case_owner_id"/>
                            <field name="review_coordinator_id"/>
                        </group>
                    </group>
                    <group string="Readiness &amp; Completion">
                        <field name="completion_rate" widget="progressbar" readonly="1"/>
                        <field name="readiness_score" widget="progressbar" readonly="1"/>
                        <field name="open_deficiency_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Summary"><field name="summary_note" nolabel="1"/></page>
                        <page string="Application Lines">
                            <field name="chapter_ids" readonly="1">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="completion_rate" widget="progressbar"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Indicators">
                            <field name="indicator_ids" readonly="1">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="response_state" widget="badge"/>
                                    <field name="completion_rate" widget="progressbar"/>
                                    <field name="compliance_result" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Deficiencies">
                            <field name="deficiency_ids">
                                <tree>
                                    <field name="title"/>
                                    <field name="severity" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                    <field name="due_date"/>
                                    <field name="attachment" filename="attachment_name" widget="binary"/>
                                    <field name="attachment_name" column_invisible="True"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Review Summary"><field name="review_summary" nolabel="1"/></page>
                        <page string="Decision Summary"><field name="decision_summary" nolabel="1"/></page>
                        <page string="State History">
                            <field name="state_history_ids" readonly="1">
                                <tree>
                                    <field name="changed_on"/>
                                    <field name="from_state"/>
                                    <field name="to_state"/>
                                    <field name="action_name"/>
                                    <field name="changed_by"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_caqa_application_indicator_tree" model="ir.ui.view">
        <field name="name">caqa.application.indicator.tree</field>
        <field name="model">caqa.application.indicator</field>
        <field name="arch" type="xml">
            <tree>
                <field name="application_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="response_state" widget="badge"/>
                <field name="completion_rate" widget="progressbar"/>
                <field name="evidence_completion_rate" widget="progressbar"/>
                <field name="open_deficiency_count"/>
                <field name="compliance_result" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_application_indicator_form" model="ir.ui.view">
        <field name="name">caqa.application.indicator.form</field>
        <field name="model">caqa.application.indicator</field>
        <field name="arch" type="xml">
            <form string="Application Indicator">
                <sheet>
                    <group>
                        <group>
                            <field name="application_id"/>
                            <field name="indicator_id"/>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="indicator_type"/>
                            <field name="response_state"/>
                            <field name="compliance_result"/>
                            <field name="completion_rate" widget="progressbar"/>
                            <field name="evidence_completion_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <field name="narrative_html" nolabel="1"/>
                    <field name="checkpoint_ids" readonly="1">
                        <tree>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="state" widget="badge"/>
                            <field name="score"/>
                        </tree>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_caqa_application_deficiency_tree" model="ir.ui.view">
        <field name="name">caqa.application.deficiency.tree</field>
        <field name="model">caqa.application.deficiency</field>
        <field name="arch" type="xml">
            <tree decoration-danger="severity in ('high','critical')" decoration-success="state in ('resolved','closed')">
                <field name="application_id"/>
                <field name="title"/>
                <field name="severity" widget="badge"/>
                <field name="assigned_user_id"/>
                <field name="due_date"/>
                <field name="attachment" filename="attachment_name" widget="binary"/>
                <field name="attachment_name" column_invisible="True"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_application_deficiency_form" model="ir.ui.view">
        <field name="name">caqa.application.deficiency.form</field>
        <field name="model">caqa.application.deficiency</field>
        <field name="arch" type="xml">
            <form string="Deficiency">
                <header>
                    <button name="action_mark_responded" type="object" string="Responded" invisible="state != 'open'"/>
                    <button name="action_resolve" type="object" string="Resolve" invisible="state not in ('open','responded')"/>
                    <button name="action_close" type="object" string="Close" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,responded,resolved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="application_id"/>
                            <field name="application_indicator_id"/>
                            <field name="title"/>
                            <field name="severity"/>
                        </group>
                        <group>
                            <field name="assigned_user_id"/>
                            <field name="due_date"/>
                            <field name="source_reference"/>
                            <field name="attachment" filename="attachment_name" widget="binary"/>
                            <field name="attachment_name" column_invisible="True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description" nolabel="1"/></page>
                        <page string="Institution Response"><field name="institution_response" nolabel="1"/></page>
                        <page string="Resolution"><field name="resolution_note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_caqa_application_state_history_tree" model="ir.ui.view">
        <field name="name">caqa.application.state.history.tree</field>
        <field name="model">caqa.application.state.history</field>
        <field name="arch" type="xml">
            <tree>
                <field name="application_id"/>
                <field name="changed_on"/>
                <field name="from_state"/>
                <field name="to_state"/>
                <field name="action_name"/>
                <field name="changed_by"/>
            </tree>
        </field>
    </record>

    <record id="action_caqa_application" model="ir.actions.act_window">
        <field name="name">Applications</field>
        <field name="res_model">caqa.application</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_caqa_application_indicator" model="ir.actions.act_window">
        <field name="name">Application Indicators</field>
        <field name="res_model">caqa.application.indicator</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_caqa_application_deficiency" model="ir.actions.act_window">
        <field name="name">Deficiencies</field>
        <field name="res_model">caqa.application.deficiency</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_caqa_application_state_history" model="ir.actions.act_window">
        <field name="name">State History</field>
        <field name="res_model">caqa.application.state.history</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
