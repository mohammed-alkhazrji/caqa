<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_standard_version_tree" model="ir.ui.view">
        <field name="name">caqa.standard.version.tree</field>
        <field name="model">caqa.standard.version</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'active'" decoration-muted="state == 'retired'">
                <field name="code"/>
                <field name="name"/>
                <field name="framework_id"/>
                <field name="accreditation_type_id"/>
                <field name="effective_start_date"/>
                <field name="effective_end_date"/>
                <field name="chapter_count"/>
                <field name="indicator_count"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_standard_version_search" model="ir.ui.view">
        <field name="name">caqa.standard.version.search</field>
        <field name="model">caqa.standard.version</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="framework_id"/>
                <field name="accreditation_type_id"/>
                <field name="state"/>
                <group expand="0" string="Group By">
                    <filter name="group_framework" string="Framework" context="{'group_by': 'framework_id'}"/>
                    <filter name="group_type" string="Accreditation Type" context="{'group_by': 'accreditation_type_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_caqa_standard_version_form" model="ir.ui.view">
        <field name="name">caqa.standard.version.form</field>
        <field name="model">caqa.standard.version</field>
        <field name="arch" type="xml">
            <form string="Standard Version">
                <header>
                    <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="state == 'active'"/>
                    <button name="action_retire" type="object" string="Retire" class="btn-secondary" invisible="state == 'retired'"/>
                    <button name="action_reset_draft" type="object" string="Reset Draft" class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,retired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_chapters" class="oe_stat_button" icon="fa-list-ul"><field name="chapter_count" widget="statinfo" string="Chapters"/></button>
                    </div>
                    <div class="oe_title"><h1><field name="name"/></h1><div class="text-muted"><field name="code"/></div></div>
                    <group>
                        <group><field name="framework_id"/><field name="accreditation_type_id"/><field name="is_default"/></group>
                        <group><field name="effective_start_date"/><field name="effective_end_date"/><field name="active"/></group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description" widget="html"/></page>
                        <page string="Chapters"><field name="chapter_ids"><tree><field name="code"/><field name="name"/><field name="weight"/><field name="subchapter_count"/></tree></field></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_caqa_standard_version" model="ir.actions.act_window">
        <field name="name">Standard Versions</field>
        <field name="res_model">caqa.standard.version</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_caqa_standard_version_search"/>
    </record>
</odoo>
