<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_standard_chapter_tree" model="ir.ui.view">
        <field name="name">caqa.standard.chapter.tree</field>
        <field name="model">caqa.standard.chapter</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="version_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="weight"/>
                <field name="subchapter_count"/>
                <field name="indicator_count"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_standard_chapter_search" model="ir.ui.view">
        <field name="name">caqa.standard.chapter.search</field>
        <field name="model">caqa.standard.chapter</field>
        <field name="arch" type="xml">
            <search>
                <field name="version_id"/>
                <field name="code"/>
                <field name="name"/>
            </search>
        </field>
    </record>
    <record id="view_caqa_standard_chapter_form" model="ir.ui.view">
        <field name="name">caqa.standard.chapter.form</field>
        <field name="model">caqa.standard.chapter</field>
        <field name="arch" type="xml">
            <form string="Standard Chapter">
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="version_id"/>
                            <field name="sequence"/>
                            <field name="code"/>
                            <field name="weight"/>
                        </group>
                        <group>
                            <field name="subchapter_count" readonly="1"/>
                            <field name="indicator_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description" nolabel="1"/></page>
                        <page string="Subchapters"><field name="subchapter_ids"><tree><field name="code"/><field name="name"/><field name="weight"/></tree></field></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_caqa_standard_chapter" model="ir.actions.act_window">
        <field name="name">Standard Chapters</field>
        <field name="res_model">caqa.standard.chapter</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
