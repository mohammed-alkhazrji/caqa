<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_eligibility_request_tree" model="ir.ui.view">
        <field name="name">caqa.eligibility.request.tree</field>
        <field name="model">caqa.eligibility.request</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'eligible'" decoration-danger="state == 'ineligible'">
                <field name="reference"/>
                <field name="institution_id"/>
                <field name="program_id"/>
                <field name="cycle_id"/>
                <field name="checklist_completion" widget="progressbar"/>
                <field name="readiness_score" widget="progressbar"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_eligibility_request_form" model="ir.ui.view">
        <field name="name">caqa.eligibility.request.form</field>
        <field name="model">caqa.eligibility.request</field>
        <field name="arch" type="xml">
            <form string="Eligibility Request">
                <header>
                    <button name="action_set_in_progress" string="Start" type="object" invisible="state != 'draft'"/>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state not in ('draft','in_progress')"/>
                    <button name="action_under_review" string="Under Review" type="object" invisible="state != 'submitted'"/>
                    <button name="action_mark_eligible" string="Mark Eligible" type="object" class="btn-primary" invisible="state != 'under_review'"/>
                    <button name="action_mark_ineligible" string="Mark Ineligible" type="object" invisible="state != 'under_review'"/>
                    <button name="action_close" string="Close" type="object" invisible="state in ('closed',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,submitted,under_review,eligible,ineligible,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_applications" type="object" class="oe_stat_button" icon="fa-files-o">
                            <field name="application_count" widget="statinfo" string="Applications"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <div class="text-muted"><field name="reference" readonly="1"/></div>
                    </div>
                    <group>
                        <group>
                            <field name="institution_id"/>
                            <field name="program_id"/>
                            <field name="accreditation_type_id"/>
                            <field name="cycle_id"/>
                        </group>
                        <group>
                            <field name="standard_version_id"/>
                            <field name="request_date"/>
                            <field name="institution_type_id" readonly="1"/>
                            <field name="eligible_for_application" readonly="1"/>
                        </group>
                    </group>
                    <group string="Readiness">
                        <field name="checklist_completion" widget="progressbar" readonly="1"/>
                        <field name="profile_readiness" widget="progressbar" readonly="1"/>
                        <field name="program_readiness" widget="progressbar" readonly="1"/>
                        <field name="readiness_score" widget="progressbar" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Checklist">
                            <field name="checklist_line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="is_required"/>
                                    <field name="provided"/>
                                    <field name="reviewer_verified"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Institution Note"><field name="note" nolabel="1"/></page>
                        <page string="Review Note"><field name="review_note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_caqa_eligibility_request_search" model="ir.ui.view">
        <field name="name">caqa.eligibility.request.search</field>
        <field name="model">caqa.eligibility.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="institution_id"/>
                <field name="program_id"/>
                <field name="state"/>
                <group expand="0" string="Group By">
                    <filter string="Institution" name="grp_institution" context="{'group_by': 'institution_id'}"/>
                    <filter string="State" name="grp_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_caqa_eligibility_request" model="ir.actions.act_window">
        <field name="name">Eligibility Requests</field>
        <field name="res_model">caqa.eligibility.request</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
