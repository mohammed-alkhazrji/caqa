<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Programs List View -->
    <template id="portal_caqa_programs" name="My Programs">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Programs</t>
            </t>
            <t t-if="not programs">
                <p class="mt-3">There are currently no programs for your institution.</p>
            </t>
            <div class="mb-3 mt-3 text-right">
                <a href="/my/caqa/program/new" class="btn btn-primary"><i class="fa fa-plus-circle"/> Request New Program</a>
            </div>
            <t t-if="programs">
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover mt-4">
                        <thead class="thead-light">
                            <tr>
                                <th>Name</th>
                                <th>Arabic Name</th>
                                <th>Code</th>
                                <th>Degree Level</th>
                                <th>State</th>
                                <th>Profile Completion</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="programs" t-as="program">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/caqa/program/#{program.id}">
                                            <t t-esc="program.name"/>
                                        </a>
                                    </td>
                                    <td><span t-esc="program.arabic_name"/></td>
                                    <td><span t-esc="program.code"/></td>
                                    <td><span t-esc="dict(program.fields_get(allfields=['degree_level'])['degree_level']['selection'])[program.degree_level]"/></td>
                                    <td>
                                        <span t-attf-class="badge badge-pill #{'badge-info' if program.state == 'draft' else 'badge-success' if program.state == 'active' else 'badge-secondary'}">
                                            <t t-esc="dict(program.fields_get(allfields=['state'])['state']['selection'])[program.state]"/>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div t-attf-class="progress-bar #{'bg-success' if program.profile_completion >= 100 else 'bg-warning'}" 
                                                 role="progressbar" 
                                                 t-attf-style="width:#{program.profile_completion}%;"
                                                 t-att-aria-valuenow="program.profile_completion" aria-valuemin="0" aria-valuemax="100">
                                                <t t-esc="int(program.profile_completion)"/>%
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- Program Creation Form -->
    <template id="portal_caqa_program_form_new" name="New Program Request">
        <t t-call="portal.portal_layout">
            <div class="container mt-4 mb-4">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Request New Program</h4>
                    </div>
                    <div class="card-body">
                        <form action="/my/caqa/program/new" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="name">Program Name (English) *</label>
                                    <input type="text" class="form-control" name="name" required="required"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="arabic_name">Program Name (Arabic)</label>
                                    <input type="text" class="form-control" name="arabic_name" dir="rtl"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="code">Program Code *</label>
                                    <input type="text" class="form-control" name="code" required="required"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="degree_level">Degree Level</label>
                                    <select class="form-control" name="degree_level">
                                        <option value="diploma">Diploma</option>
                                        <option value="bachelor" selected="selected">Bachelor</option>
                                        <option value="master">Master</option>
                                        <option value="doctorate">Doctorate</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="delivery_mode">Delivery Mode</label>
                                    <select class="form-control" name="delivery_mode">
                                        <option value="onsite" selected="selected">Onsite</option>
                                        <option value="online">Online</option>
                                        <option value="blended">Blended</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="language">Language of Instruction</label>
                                    <select class="form-control" name="language">
                                        <option value="ar" selected="selected">Arabic</option>
                                        <option value="en">English</option>
                                        <option value="bilingual">Bilingual</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="college_name">College Name</label>
                                    <input type="text" class="form-control" name="college_name"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="department_name">Department Name</label>
                                    <input type="text" class="form-control" name="department_name"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="duration_years">Duration (Years)</label>
                                    <input type="number" step="0.5" class="form-control" name="duration_years" value="4.0"/>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="credit_hours">Total Credit Hours</label>
                                    <input type="number" step="1" class="form-control" name="credit_hours" value="120"/>
                                </div>
                            </div>
                            <div class="mt-4 text-center">
                                <button type="submit" class="btn btn-primary"><i class="fa fa-save"/> Create Program Request</button>
                                <a href="/my/caqa/programs" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Program Detail / Edit Form -->
    <template id="portal_caqa_program_detail" name="Program Detail">
        <t t-call="portal.portal_layout">
            <t t-set="is_editable" t-value="program.state == 'draft'"/>
            <div class="container mt-4 mb-4">
                <div class="card">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><t t-esc="program.name"/> - <t t-esc="program.reference"/></h4>
                        <span t-attf-class="badge badge-pill #{'badge-info' if program.state == 'draft' else 'badge-success'}">
                            <t t-esc="dict(program.fields_get(allfields=['state'])['state']['selection'])[program.state]"/>
                        </span>
                    </div>
                    
                    <t t-if="is_editable">
                        <div class="alert alert-info border-0 rounded-0 mb-0">
                            <i class="fa fa-info-circle"/> <strong>Draft Mode:</strong> You can edit the program details. Ensure all data is saved before submitting an application. Active programs cannot be modified by the institution.
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-warning border-0 rounded-0 mb-0">
                            <i class="fa fa-lock"/> <strong>Locked:</strong> This program is no longer in Draft status. Modifications must be requested through your Accreditation manager.
                        </div>
                    </t>

                    <div class="card-body">
                        
                        <form t-attf-action="/my/caqa/program/#{program.id}" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            
                            <!-- MAIN OVERVIEW -->
                            <h5 class="border-bottom pb-2 mb-3">General Information</h5>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Program Name (English) *</label>
                                    <t t-if="is_editable"><input type="text" class="form-control" name="name" t-att-value="program.name" required="required"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.name"/></p></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Program Name (Arabic)</label>
                                    <t t-if="is_editable"><input type="text" class="form-control" name="arabic_name" t-att-value="program.arabic_name" dir="rtl"/></t>
                                    <t t-else=""><p class="form-control-plaintext" dir="rtl"><t t-esc="program.arabic_name"/></p></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Program Code *</label>
                                    <t t-if="is_editable"><input type="text" class="form-control" name="code" t-att-value="program.code" required="required"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.code"/></p></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Degree Level</label>
                                    <t t-if="is_editable">
                                        <select class="form-control" name="degree_level">
                                            <option value="diploma" t-att-selected="program.degree_level == 'diploma'">Diploma</option>
                                            <option value="bachelor" t-att-selected="program.degree_level == 'bachelor'">Bachelor</option>
                                            <option value="master" t-att-selected="program.degree_level == 'master'">Master</option>
                                            <option value="doctorate" t-att-selected="program.degree_level == 'doctorate'">Doctorate</option>
                                        </select>
                                    </t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="dict(program.fields_get(allfields=['degree_level'])['degree_level']['selection'])[program.degree_level]"/></p></t>
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">College Name</label>
                                    <t t-if="is_editable"><input type="text" class="form-control" name="college_name" t-att-value="program.college_name"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.college_name or '-'"/></p></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Department Name</label>
                                    <t t-if="is_editable"><input type="text" class="form-control" name="department_name" t-att-value="program.department_name"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.department_name or '-'"/></p></t>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="font-weight-bold">Duration (Years)</label>
                                    <t t-if="is_editable"><input type="number" step="0.5" class="form-control" name="duration_years" t-att-value="program.duration_years"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.duration_years"/></p></t>
                                </div>
                                <div class="col-md-3 mb-3">
                                    <label class="font-weight-bold">Credit Hours</label>
                                    <t t-if="is_editable"><input type="number" step="1" class="form-control" name="credit_hours" t-att-value="program.credit_hours"/></t>
                                    <t t-else=""><p class="form-control-plaintext"><t t-esc="program.credit_hours"/></p></t>
                                </div>
                            </div>
                            
                            <h5 class="border-bottom pb-2 mt-4 mb-3">Strategic Context</h5>
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="font-weight-bold">Description</label>
                                    <t t-if="is_editable"><textarea class="form-control" name="description" rows="3"><t t-raw="program.description"/></textarea></t>
                                    <t t-else=""><div class="form-control-plaintext border p-2 bg-light"><t t-raw="program.description or '-'"/></div></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Vision</label>
                                    <t t-if="is_editable"><textarea class="form-control" name="vision" rows="4"><t t-raw="program.vision"/></textarea></t>
                                    <t t-else=""><div class="form-control-plaintext border p-2 bg-light"><t t-raw="program.vision or '-'"/></div></t>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold">Mission</label>
                                    <t t-if="is_editable"><textarea class="form-control" name="mission" rows="4"><t t-raw="program.mission"/></textarea></t>
                                    <t t-else=""><div class="form-control-plaintext border p-2 bg-light"><t t-raw="program.mission or '-'"/></div></t>
                                </div>
                            </div>
                            
                            <t t-if="is_editable">
                                <div class="text-right mt-3 mb-4">
                                    <button type="submit" class="btn btn-primary"><i class="fa fa-save"/> Save Changes</button>
                                </div>
                            </t>
                        </form>
                        
                        <!-- TABBED CONTENT (Courses & Learning Outcomes) -->
                        <ul class="nav nav-tabs mt-5" id="programTabs" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="courses-tab" data-bs-toggle="tab" data-toggle="tab" href="#courses" role="tab">Courses (<t t-esc="program.course_count"/>)</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="lo-tab" data-bs-toggle="tab" data-toggle="tab" href="#lo" role="tab">Learning Outcomes (<t t-esc="program.learning_outcome_count"/>)</a>
                            </li>
                        </ul>
                        
                        <div class="tab-content border border-top-0 p-3" id="programTabsContent">
                            <!-- Courses Tab -->
                            <div class="tab-pane fade show active" id="courses" role="tabpanel">
                                <t t-if="is_editable">
                                    <div class="text-right mb-3">
                                        <button type="button" class="btn btn-sm btn-outline-primary" data-toggle="modal" data-bs-toggle="modal" data-target="#courseModal" data-bs-target="#courseModal">
                                            <i class="fa fa-plus"/> Add Course
                                        </button>
                                    </div>
                                </t>
                                
                                <table class="table table-sm table-striped">
                                    <thead>
                                        <tr>
                                            <th>Code</th>
                                            <th>Course Name</th>
                                            <th>Credits</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="program.course_ids" t-as="course">
                                            <tr>
                                                <td><t t-esc="course.code"/></td>
                                                <td><t t-esc="course.name"/></td>
                                                <td><t t-esc="course.credit_hours"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="not program.course_ids">
                                            <tr><td colspan="3" class="text-center text-muted">No courses added yet.</td></tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                            
                            <!-- Learning Outcomes Tab -->
                            <div class="tab-pane fade" id="lo" role="tabpanel">
                                <t t-if="is_editable">
                                    <div class="text-right mb-3">
                                        <button type="button" class="btn btn-sm btn-outline-primary" data-toggle="modal" data-bs-toggle="modal" data-target="#loModal" data-bs-target="#loModal">
                                            <i class="fa fa-plus"/> Add Learning Outcome
                                        </button>
                                    </div>
                                </t>
                                
                                <table class="table table-sm table-striped">
                                    <thead>
                                        <tr>
                                            <th>Code</th>
                                            <th>Name</th>
                                            <th>Type</th>
                                            <th>Description</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="program.learning_outcome_ids" t-as="lo">
                                            <tr>
                                                <td><t t-esc="lo.code"/></td>
                                                <td><t t-esc="lo.name"/></td>
                                                <td><t t-esc="dict(lo.fields_get(allfields=['outcome_type'])['outcome_type']['selection'])[lo.outcome_type]"/></td>
                                                <td><t t-raw="lo.description"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="not program.learning_outcome_ids">
                                            <tr><td colspan="4" class="text-center text-muted">No learning outcomes added yet.</td></tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            
            <!-- Modals for Add Course and Add LO (only in draft) -->
            <t t-if="is_editable">
                <!-- Add Course Modal -->
                <div class="modal fade" id="courseModal" tabindex="-1" role="dialog">
                    <div class="modal-dialog" role="document">
                        <form t-attf-action="/my/caqa/program/#{program.id}/course/add" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Add Course</h5>
                                    <button type="button" class="close btn-close" data-dismiss="modal" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="form-group mb-2">
                                        <label>Course Code *</label>
                                        <input type="text" class="form-control" name="code" required="required"/>
                                    </div>
                                    <div class="form-group mb-2">
                                        <label>Course Name *</label>
                                        <input type="text" class="form-control" name="name" required="required"/>
                                    </div>
                                    <div class="form-group mb-2">
                                        <label>Credit Hours</label>
                                        <input type="number" step="0.5" class="form-control" name="credit_hours" value="3.0"/>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-dismiss="modal" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary"><i class="fa fa-plus"/> Add Course</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Add Learning Outcome Modal -->
                <div class="modal fade" id="loModal" tabindex="-1" role="dialog">
                    <div class="modal-dialog" role="document">
                        <form t-attf-action="/my/caqa/program/#{program.id}/lo/add" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Add Learning Outcome</h5>
                                    <button type="button" class="close btn-close" data-dismiss="modal" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="form-group mb-2">
                                        <label>Outcome Code * (e.g., K1, S1, V1)</label>
                                        <input type="text" class="form-control" name="code" required="required"/>
                                    </div>
                                    <div class="form-group mb-2">
                                        <label>Outcome Name *</label>
                                        <input type="text" class="form-control" name="name" required="required"/>
                                    </div>
                                    <div class="form-group mb-2">
                                        <label>Domain Type</label>
                                        <select class="form-control" name="outcome_type">
                                            <option value="knowledge">Knowledge</option>
                                            <option value="skill">Skill</option>
                                            <option value="value">Value</option>
                                        </select>
                                    </div>
                                    <div class="form-group mb-2">
                                        <label>Description</label>
                                        <textarea class="form-control" name="description" rows="3"></textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-dismiss="modal" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary"><i class="fa fa-plus"/> Add Outcome</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </t>
            
        </t>
    </template>

</odoo>
