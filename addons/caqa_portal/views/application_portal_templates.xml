<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Application Detail Template with Tabs -->
    <template id="portal_caqa_application_detail">
        <t t-call="caqa_portal.portal_caqa_layout">
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
                    <div>
                        <h5 class="mb-0"><t t-esc="application.reference"/> — <t t-esc="application.name"/></h5>
                    </div>
                    <span t-attf-class="badge #{'bg-primary' if application.state in ['draft', 'in_progress'] else 'bg-success'}">
                        <t t-esc="dict(application._fields['state'].selection).get(application.state)"/>
                    </span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="small fw-bold text-muted">Application Progress</div>
                            <div class="progress mt-1" style="height: 20px;">
                                <div class="progress-bar bg-info" t-attf-style="width:#{application.completion_rate}%;">
                                    <t t-esc="'%.1f' % application.completion_rate"/>%
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="small fw-bold text-muted">Readiness Score</div>
                            <div class="progress mt-1" style="height: 20px;">
                                <div class="progress-bar bg-success" t-attf-style="width:#{application.readiness_score}%;">
                                    <t t-esc="'%.1f' % application.readiness_score"/>%
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="small fw-bold text-muted">Open Deficiencies</div>
                            <h3 class="mb-0 text-danger"><t t-esc="application.open_deficiency_count"/></h3>
                        </div>
                    </div>
                    <div class="mt-4 d-flex justify-content-end gap-2 align-items-center">
                        <!-- Lock message for in_progress (data is locked, only evidences/forms allowed) -->
                        <t t-if="application.state == 'in_progress'">
                            <span class="text-muted small me-auto"><i class="fa fa-lock"/> Application data is locked. You can only upload evidence and fill forms.</span>
                        </t>
                        <t t-if="application.state == 'draft'">
                            <!-- Info: still in draft, can edit data -->
                            <span class="text-warning small me-auto"><i class="fa fa-exclamation-triangle"/> Draft mode — click Start to lock data and generate the accreditation structure.</span>
                        </t>
                        <!-- START: generates structure and locks the data -->
                        <form t-if="application.state == 'draft'" method="post" t-att-action="'/my/caqa/application/%s/start' % application.id">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm" onclick="return confirm('Are you sure you want to start accreditation? This will lock the application data and generate the evaluation structure.')">
                                <i class="fa fa-play-circle"/> Start Accreditation
                            </button>
                        </form>
                        <!-- Submit for review -->
                        <form t-if="application.state == 'in_progress'" method="post" t-att-action="'/my/caqa/application/%s/submit' % application.id">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-primary px-4 fw-bold"><i class="fa fa-paper-plane"/> Submit Application</button>
                        </form>
                        <!-- Resubmit if more info was needed -->
                        <form t-if="application.state == 'need_more_information'" method="post" t-att-action="'/my/caqa/application/%s/resubmit' % application.id">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" class="btn btn-warning px-4 fw-bold"><i class="fa fa-refresh"/> Resubmit Fixes</button>
                        </form>
                    </div>
                </div>
            </div>
            
            <!-- Tabs Navigation -->
            <ul class="nav nav-tabs" id="applicationTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold text-dark" id="indicators-tab" data-bs-toggle="tab" data-bs-target="#indicators" type="button" role="tab" aria-controls="indicators" aria-selected="true">
                        <i class="fa fa-list"/> Indicators
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-dark" id="sar-tab" data-bs-toggle="tab" data-bs-target="#sar" type="button" role="tab" aria-controls="sar" aria-selected="false">
                        <i class="fa fa-file-text-o"/> Self Assessment (SAR)
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-dark" id="deficiencies-tab" data-bs-toggle="tab" data-bs-target="#deficiencies" type="button" role="tab" aria-controls="deficiencies" aria-selected="false">
                        <i class="fa fa-exclamation-circle text-danger"/> Deficiencies
                        <t t-if="application.open_deficiency_count">
                            <span class="badge bg-danger ms-1 rounded-pill"><t t-esc="application.open_deficiency_count"/></span>
                        </t>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-dark" id="evidences-tab" data-bs-toggle="tab" data-bs-target="#evidences" type="button" role="tab" aria-controls="evidences" aria-selected="false">
                        <i class="fa fa-folder-open"/> Evidences Tracker
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-dark" id="forms-tab" data-bs-toggle="tab" data-bs-target="#forms" type="button" role="tab" aria-controls="forms" aria-selected="false">
                        <i class="fa fa-wpforms"/> Evaluation Forms
                    </button>
                </li>
            </ul>
            
            <!-- Tabs Content -->
            <div class="tab-content bg-white border border-top-0 p-4 mb-5 shadow-sm" id="applicationTabsContent">
                
                <!-- Indicators Tab -->
                <div class="tab-pane fade show active" id="indicators" role="tabpanel" aria-labelledby="indicators-tab">
                    <t t-if="application.indicator_ids">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Code</th>
                                        <th>Indicator Title</th>
                                        <th>Status</th>
                                        <th>Completion</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="application.indicator_ids" t-as="ind">
                                        <td class="fw-bold text-primary"><t t-esc="ind.code"/></td>
                                        <td><t t-esc="ind.name"/></td>
                                        <td><span class="badge bg-secondary"><t t-esc="dict(ind._fields['response_state'].selection).get(ind.response_state)"/></span></td>
                                        <td>
                                            <div class="progress" style="height: 10px;">
                                                <div class="progress-bar" t-attf-style="width:#{ind.completion_rate}%;"></div>
                                            </div>
                                            <small class="text-muted"><t t-esc="'%.1f' % ind.completion_rate"/>%</small>
                                        </td>
                                        <td class="text-end">
                                            <a t-att-href="'/my/caqa/indicator/%s' % ind.id" class="btn btn-sm btn-outline-primary shadow-sm"><i class="fa fa-pencil"/> Assess</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-warning mb-0 border-0"><i class="fa fa-warning"/> Standard structure has not been generated for this application yet.</div>
                    </t>
                </div>
                
                <!-- SAR Tab -->
                <div class="tab-pane fade" id="sar" role="tabpanel" aria-labelledby="sar-tab">
                    <t t-if="application.sar_version_ids">
                        <div class="list-group">
                            <t t-foreach="application.sar_version_ids" t-as="sar">
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center flex-wrap">
                                    <div>
                                        <h6 class="mb-1 fw-bold"><i class="fa fa-book"/> <t t-out="sar.name"/></h6>
                                        <small class="text-muted">Generated: <t t-esc="sar.generated_on" t-options="{'widget': 'datetime'}"/></small>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="min-width: 150px;">
                                            <div class="small text-muted mb-1 text-end">Completion <t t-esc="'%.1f' % sar.completion_rate"/>%</div>
                                            <div class="progress" style="height: 8px;">
                                                <div class="progress-bar bg-success" t-attf-style="width:#{sar.completion_rate}%;"></div>
                                            </div>
                                        </div>
                                        <span class="badge bg-info"><t t-esc="dict(sar._fields['state'].selection).get(sar.state)"/></span>
                                        <!-- NOTE: Currently SAR editing might not have a portal route directly unless added. Providing a placeholder view link for continuity -->
                                        <!-- <a t-att-href="'/my/caqa/sar/%s' % sar.id" class="btn btn-sm btn-success shadow-sm px-3"><i class="fa fa-eye"/> Setup Sections</a> -->
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-secondary border-0 mb-0"><i class="fa fa-info-circle"/> No Self Assessment Reports (SAR) have been initialized.</div>
                    </t>
                </div>
                
                <!-- Evidences Tab -->
                <div class="tab-pane fade" id="evidences" role="tabpanel" aria-labelledby="evidences-tab">
                    <div class="alert alert-info border-0"><i class="fa fa-info-circle"/> <strong>Required Evidences:</strong> The list below automatically identifies all standard requirements needed for compliance. Click on each requirement to upload the corresponding documents.</div>
                    
                    <t t-if="application.evidence_ids">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Evidence Name</th>
                                        <th>Requirement Target</th>
                                        <th>Completion</th>
                                        <th>Status</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="application.evidence_ids" t-as="ev">
                                        <td class="fw-bold"><t t-esc="ev.name"/></td>
                                        <td class="text-muted"><t t-out="ev.requirement_id.name if ev.requirement_id else 'General'"/></td>
                                        <td>
                                            <div class="progress" style="height: 10px;">
                                                <div t-attf-class="progress-bar #{'bg-success' if ev.validation_completion_rate == 100 else 'bg-warning'}" t-attf-style="width:#{ev.validation_completion_rate}%;"></div>
                                            </div>
                                            <small class="text-muted"><t t-esc="'%.1f' % ev.validation_completion_rate"/>%</small>
                                        </td>
                                        <td>
                                            <span t-attf-class="badge #{'bg-success' if ev.state in ['submitted', 'accepted'] else 'bg-secondary'}">
                                                <t t-esc="dict(ev._fields['state'].selection).get(ev.state)"/>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <a t-att-href="'/my/caqa/evidence/%s' % ev.id" class="btn btn-sm btn-primary shadow-sm"><i class="fa fa-upload"/> Upload</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-secondary border-0 mb-0"><i class="fa fa-info-circle"/> No evidence requests found. They are generated alongside the indicators structural map.</div>
                    </t>
                </div>
                
                <!-- Forms Tab -->
                <div class="tab-pane fade" id="forms" role="tabpanel" aria-labelledby="forms-tab">
                    <t t-if="application.form_response_ids">
                        <div class="row g-3">
                            <t t-foreach="application.form_response_ids" t-as="form_resp">
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 shadow-sm bg-light">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <h6 class="card-title fw-bold text-primary mb-0"><i class="fa fa-list-alt"/> <t t-esc="form_resp.template_id.name"/></h6>
                                                <span t-attf-class="badge #{'bg-success' if form_resp.state == 'submitted' else 'bg-secondary'}"><t t-esc="dict(form_resp._fields['state'].selection).get(form_resp.state)"/></span>
                                            </div>
                                            <p class="card-text small text-muted mb-3">This mandatory evaluation form must be completed as part of your accreditation profile.</p>
                                            
                                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                                <div style="min-width: 100px;">
                                                    <div class="small fw-bold mb-1"><t t-esc="'%.1f' % form_resp.completion_rate"/>% Completed</div>
                                                    <div class="progress" style="height: 6px;">
                                                        <div class="progress-bar bg-success" t-attf-style="width:#{form_resp.completion_rate}%;"></div>
                                                    </div>
                                                </div>
                                                <a t-att-href="'/my/caqa/form/%s' % form_resp.id" class="btn btn-primary btn-sm px-3 shadow-sm rounded-pill"><i class="fa fa-pencil"/> Fill Form</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-secondary border-0 mb-0"><i class="fa fa-check-circle"/> No evaluation forms are required for this application type.</div>
                    </t>
                </div>
                
                <!-- Deficiencies Tab -->
                <div class="tab-pane fade" id="deficiencies" role="tabpanel" aria-labelledby="deficiencies-tab">
                    <t t-if="application.deficiency_ids">
                        <div class="alert alert-info border-0 small mb-3">
                            <i class="fa fa-info-circle"/> <strong>Action Required:</strong> Review each deficiency and submit your institution's response. Open deficiencies must be addressed before final approval.
                        </div>
                        <div class="accordion" id="deficiencyAccordion">
                            <t t-foreach="application.deficiency_ids" t-as="def_rec">
                                <div t-attf-class="accordion-item border #{'border-success' if def_rec.state in ['resolved','closed'] else 'border-primary' if def_rec.state == 'responded' else 'border-danger'} mb-2 rounded">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed fw-bold"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                t-attf-data-bs-target="#def_collapse_#{def_rec.id}"
                                                aria-expanded="false">
                                            <div class="d-flex justify-content-between w-100 align-items-center me-3">
                                                <span>
                                                    <span t-attf-class="badge me-2 #{'bg-danger' if def_rec.severity == 'critical' else 'bg-warning text-dark' if def_rec.severity == 'high' else 'bg-info' if def_rec.severity == 'medium' else 'bg-secondary'}">
                                                        <t t-esc="dict(def_rec._fields['severity'].selection).get(def_rec.severity)"/>
                                                    </span>
                                                    <t t-esc="def_rec.title"/>
                                                </span>
                                                <span t-attf-class="badge #{'bg-success' if def_rec.state in ['resolved','closed'] else 'bg-primary' if def_rec.state == 'responded' else 'bg-danger'}">
                                                    <t t-esc="dict(def_rec._fields['state'].selection).get(def_rec.state)"/>
                                                </span>
                                            </div>
                                        </button>
                                    </h2>
                                    <div t-attf-id="def_collapse_#{def_rec.id}" class="accordion-collapse collapse" data-bs-parent="#deficiencyAccordion">
                                        <div class="accordion-body">
                                            <!-- Deficiency Details -->
                                            <div class="row g-2 mb-3 text-muted small">
                                                <div class="col-md-4">
                                                    <i class="fa fa-tag"/> <strong>Indicator:</strong>
                                                    <t t-esc="def_rec.application_indicator_id.code if def_rec.application_indicator_id else '—'"/>
                                                </div>
                                                <div class="col-md-4">
                                                    <i class="fa fa-calendar"/> <strong>Due:</strong>
                                                    <t t-esc="def_rec.due_date or '—'"/>
                                                </div>
                                            </div>

                                            <!-- Description (HTML) -->
                                            <t t-if="def_rec.description">
                                                <div class="bg-light border rounded p-3 mb-3 small">
                                                    <strong>Description:</strong>
                                                    <t t-esc="def_rec.description"/>
                                                </div>
                                            </t>

                                            <!-- Existing Institution Response (if already responded) -->
                                            <t t-if="def_rec.institution_response and def_rec.state != 'open'">
                                                <div class="alert alert-secondary border-0 mb-3 small">
                                                    <strong><i class="fa fa-reply"/> Your Response:</strong>
                                                    <t t-esc="def_rec.institution_response"/>
                                                </div>
                                            </t>

                                            <!-- Response Form (only if not resolved/closed) -->
                                            <t t-if="def_rec.state not in ['resolved', 'closed']">
                                                <form method="post"
                                                      t-att-action="'/my/caqa/deficiency/%s/respond' % def_rec.id">
                                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold"><i class="fa fa-pencil"/> Institution Response <span class="text-danger">*</span></label>
                                                        <textarea name="institution_response" class="form-control" rows="4"
                                                                  placeholder="Describe the corrective actions taken or explain the situation..."
                                                                  required="required"><t t-esc="def_rec.institution_response or ''"/></textarea>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">
                                                            <i class="fa fa-reply"/> Submit Response
                                                        </button>
                                                    </div>
                                                </form>
                                            </t>
                                            <t t-else="">
                                                <div class="alert alert-success border-0 mb-0 small">
                                                    <i class="fa fa-lock"/> This deficiency is <strong><t t-esc="dict(def_rec._fields['state'].selection).get(def_rec.state)"/></strong> and no further action is required.
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="alert alert-success border-0 mb-0"><i class="fa fa-check-circle"/> No deficiencies recorded for this application. Great work!</div>
                    </t>
                </div>

            </div>
            
        </t>
    </template>

    <!-- Dynamic Form Portal Response Template -->
    <template id="portal_caqa_form_response_detail">
        <t t-call="portal.portal_layout">
            <t t-set="is_draft" t-value="form_response.state == 'draft'"/>
            <div class="container mt-4 mb-5 pb-5">
                <div class="card shadow border-0">
                    <div class="card-header bg-gradient bg-primary text-white p-4">
                        <h3 class="mb-1"><t t-esc="form_response.template_id.name"/></h3>
                        <p class="mb-0 text-white-50"><t t-esc="form_response.name"/></p>
                    </div>
                    
                    <t t-if="not is_draft">
                        <div class="alert alert-success border-0 rounded-0 mb-0 px-4 py-3">
                            <i class="fa fa-lock fa-lg me-2"/> <strong>Submitted:</strong> This evaluation form has been permanently submitted and is locked from further edits.
                        </div>
                    </t>
                    
                    <div class="card-body p-4 bg-light">
                        <form t-attf-action="/my/caqa/form/#{form_response.id}" method="post" id="dynamicForm">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            
                            <t t-foreach="form_response.answer_ids" t-as="ans">
                                <t t-set="q" t-value="ans.question_id"/>
                                <div class="card mb-4 border-0 shadow-sm">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <label class="form-label h6 fw-bold text-dark mb-0">
                                                <span class="text-primary me-2"><t t-esc="q.sequence"/>.</span> <t t-esc="q.question_text"/>
                                                <span t-if="q.is_required" class="text-danger">*</span>
                                            </label>
                                            <t t-if="not is_draft and ans.is_answered">
                                                <span class="badge bg-success" style="height: fit-content;"><i class="fa fa-check"/> Answered</span>
                                            </t>
                                        </div>
                                        
                                        <p t-if="q.help_text" class="text-muted small fst-italic mb-3"><t t-esc="q.help_text"/></p>
                                        
                                        <!-- Field Handling based on field_type -->
                                        <!-- TEXT -->
                                        <t t-if="q.field_type == 'text'">
                                            <t t-if="is_draft">
                                                <textarea t-attf-name="answer_text_#{ans.id}" class="form-control" rows="4" t-att-required="q.is_required"><t t-esc="ans.answer_text or ''"/></textarea>
                                            </t>
                                            <t t-else="">
                                                <div class="p-3 bg-white border rounded text-dark"><t t-esc="ans.answer_text or 'No Response provided.'"/></div>
                                            </t>
                                        </t>
                                        
                                        <!-- NUMBER -->
                                        <t t-if="q.field_type == 'number'">
                                            <t t-if="is_draft">
                                                <input type="number" step="any" t-attf-name="answer_number_#{ans.id}" t-att-value="ans.answer_number" class="form-control w-25" t-att-required="q.is_required"/>
                                            </t>
                                            <t t-else="">
                                                <div class="p-3 bg-white border rounded text-dark fw-bold"><t t-esc="ans.answer_number"/></div>
                                            </t>
                                        </t>
                                        
                                        <!-- BOOLEAN -->
                                        <t t-if="q.field_type == 'boolean'">
                                            <t t-if="is_draft">
                                                <div class="form-check form-switch fs-5">
                                                    <input class="form-check-input" type="checkbox" t-attf-name="answer_boolean_#{ans.id}" t-att-checked="ans.answer_boolean"/>
                                                    <label class="form-check-label ms-2">Yes / Approved</label>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="p-3 bg-white border rounded">
                                                    <span t-attf-class="badge #{'bg-success' if ans.answer_boolean else 'bg-secondary'}">
                                                        <t t-esc="'Yes' if ans.answer_boolean else 'No'"/>
                                                    </span>
                                                </div>
                                            </t>
                                        </t>
                                        
                                        <!-- SELECTION -->
                                        <t t-if="q.field_type == 'selection'">
                                            <t t-set="options" t-value="(q.selection_options or '').split(',')"/>
                                            <t t-if="is_draft">
                                                <select t-attf-name="answer_selection_#{ans.id}" class="form-select w-50" t-att-required="q.is_required">
                                                    <option value="">-- Choose Option --</option>
                                                    <t t-foreach="options" t-as="opt">
                                                        <t t-set="trim_opt" t-value="opt.strip()"/>
                                                        <option t-att-value="trim_opt" t-att-selected="ans.answer_selection == trim_opt"><t t-esc="trim_opt"/></option>
                                                    </t>
                                                </select>
                                            </t>
                                            <t t-else="">
                                                <div class="p-3 bg-white border rounded fw-bold text-dark"><t t-esc="ans.answer_selection or 'No Selection made.'"/></div>
                                            </t>
                                        </t>
                                        
                                    </div>
                                </div>
                            </t>
                            
                            <!-- Action Buttons -->
                            <t t-if="is_draft">
                                <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                                    <button type="submit" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">
                                        <i class="fa fa-save"/> Save Draft
                                    </button>
                                    <button type="submit" name="submit_now" value="1" class="btn btn-success px-5 fw-bold shadow">
                                        <i class="fa fa-check-circle"/> Submit Form Responses
                                    </button>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="text-center mt-5 pt-3 border-top">
                                    <a t-att-href="'/my/caqa/application/%s' % form_response.application_id.id" class="btn btn-secondary px-5 fw-bold shadow-sm">
                                        <i class="fa fa-arrow-left"/> Return to Application
                                    </a>
                                </div>
                            </t>
                            
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
