    <record id="view_caqa_accreditation_cycle_form" model="ir.ui.view">
        <field name="name">caqa.accreditation.cycle.form</field>
        <field name="model">caqa.accreditation.cycle</field>
        <field name="arch" type="xml">
            <form string="Accreditation Cycle">
                <header>
                    <button name="action_set_draft" type="object" string="Set Draft" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_open_cycle" type="object" string="Open" class="btn-primary" invisible="state == 'open'"/>
                    <button name="action_close_cycle" type="object" string="Close" class="btn-secondary" invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <div class="text-muted"><field name="code"/></div>
                    </div>
                    <group>
                        <group>
                            <field name="framework_id"/>
                            <field name="accreditation_type_id"/>
                            <field name="academic_year"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_current" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_caqa_accreditation_cycle" model="ir.actions.act_window">
        <field name="name">Accreditation Cycles</field>
        <field name="res_model">caqa.accreditation.cycle</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
