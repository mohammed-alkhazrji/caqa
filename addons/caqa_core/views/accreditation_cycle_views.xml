<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_accreditation_cycle_tree" model="ir.ui.view">
        <field name="name">caqa.accreditation.cycle.tree</field>
        <field name="model">caqa.accreditation.cycle</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'open'" decoration-muted="state == 'closed'">
                <field name="code"/>
                <field name="name"/>
                <field name="framework_id"/>
                <field name="accreditation_type_id"/>
                <field name="academic_year"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"/>
                <field name="is_current" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

