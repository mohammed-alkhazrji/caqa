<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_accreditation_type_tree" model="ir.ui.view">
        <field name="name">caqa.accreditation.type.tree</field>
        <field name="model">caqa.accreditation.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="framework_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="scope" widget="badge"/>
                <field name="cycle_count" string="Cycles"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_caqa_accreditation_type_search" model="ir.ui.view">
        <field name="name">caqa.accreditation.type.search</field>
        <field name="model">caqa.accreditation.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="framework_id"/>
                <filter name="scope_institutional" string="Institutional" domain="[('scope', '=', 'institutional')]"/>
                <filter name="scope_programmatic" string="Programmatic" domain="[('scope', '=', 'programmatic')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_framework" string="Framework" context="{'group_by': 'framework_id'}"/>
                    <filter name="group_scope" string="Scope" context="{'group_by': 'scope'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_caqa_accreditation_type_form" model="ir.ui.view">
        <field name="name">caqa.accreditation.type.form</field>
        <field name="model">caqa.accreditation.type</field>
        <field name="arch" type="xml">
            <form string="Accreditation Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_cycles" class="oe_stat_button" icon="fa-refresh">
                            <field name="cycle_count" widget="statinfo" string="Cycles"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <div class="text-muted"><field name="code"/></div>
                    </div>
                    <group>
                        <group>
                            <field name="framework_id"/>
                            <field name="scope"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Cycles">
                            <field name="cycle_ids" readonly="1">
                                <tree decoration-success="state == 'open'" decoration-muted="state == 'closed'">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="academic_year"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_caqa_accreditation_type" model="ir.actions.act_window">
        <field name="name">Accreditation Types</field>
        <field name="res_model">caqa.accreditation.type</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_caqa_accreditation_type_search"/>
    </record>
</odoo>
