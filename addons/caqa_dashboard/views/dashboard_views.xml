<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_caqa_dashboard" model="ir.actions.client">
        <field name="name">لوحة تحكم CAQA</field>
        <field name="tag">caqa_dashboard.Dashboard</field>
        <field name="target">main</field>
    </record>

    <record id="action_caqa_standards_dashboard" model="ir.actions.client">
        <field name="name">تحليلات المعايير</field>
        <field name="tag">caqa_dashboard.StandardsDashboard</field>
        <field name="target">main</field>
    </record>

    <record id="caqa_core.menu_caqa_root" model="ir.ui.menu">
        <field name="action" ref="action_caqa_dashboard"/>
    </record>

    <menuitem id="menu_caqa_dashboard_child"
              name="لوحة القيادة"
              parent="caqa_core.menu_caqa_root" 
              action="action_caqa_dashboard" 
              sequence="1"/>

    <menuitem id="menu_caqa_standards_dashboard"
              name="المعايير" 
              parent="caqa_core.menu_caqa_root" 
              action="action_caqa_standards_dashboard" 
              sequence="2"/>
</odoo>
