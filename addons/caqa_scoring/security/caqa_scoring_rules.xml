<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule: Reviewers can read applications they are assigned to -->
        <record id="rule_caqa_application_reviewer" model="ir.rule">
            <field name="name">Score Reviewer: View Assigned Applications</field>
            <field name="model_id" ref="caqa_application.model_caqa_application"/>
            <field name="domain_force">[('score_cycle_ids.reviewer_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('caqa_scoring.group_caqa_score_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Rule: Reviewers/Managers can read cycles they are assigned to or manage -->
        <record id="rule_caqa_score_cycle_reviewer" model="ir.rule">
            <field name="name">Score Reviewer: View Assigned Cycles</field>
            <field name="model_id" ref="model_caqa_score_cycle"/>
            <field name="domain_force">['|', ('reviewer_ids', 'in', [user.id]), ('manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('caqa_scoring.group_caqa_score_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Rule: Reviewers can only read/write their own score lines. Managers can read all lines in their cycle -->
        <record id="rule_caqa_score_line_reviewer" model="ir.rule">
            <field name="name">Score Reviewer: Manage Own Score Lines</field>
            <field name="model_id" ref="model_caqa_score_line"/>
            <field name="domain_force">['|', ('reviewer_id', '=', user.id), ('cycle_id.manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('caqa_scoring.group_caqa_score_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Update existing rule to include managers -->
        <record id="rule_caqa_application_reviewer" model="ir.rule">
            <field name="name">Score Reviewer: View Assigned Applications</field>
            <field name="model_id" ref="caqa_application.model_caqa_application"/>
            <field name="domain_force">['|', ('score_cycle_ids.reviewer_ids', 'in', [user.id]), ('score_cycle_ids.manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('caqa_scoring.group_caqa_score_reviewer'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


    </data>
</odoo>
