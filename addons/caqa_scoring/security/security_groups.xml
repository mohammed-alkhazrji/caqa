<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record model="ir.module.category" id="module_category_caqa_scoring">
            <field name="name">CAQA Scoring Engine</field>
            <field name="description">Helps manage indicator scorings, moderator reviews, and decision snapshots.</field>
            <field name="sequence">25</field>
        </record>

        <!-- Reviewer Group -->
        <record id="group_caqa_score_reviewer" model="res.groups">
            <field name="name">Scoring Reviewer</field>
            <field name="category_id" ref="module_category_caqa_scoring"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view and manage their own score lines during assigned cycles.</field>
        </record>

        <!-- Lead Reviewer Group -->
        <record id="group_caqa_score_lead_reviewer" model="res.groups">
            <field name="name">Lead Reviewer / Technical Committee</field>
            <field name="category_id" ref="module_category_caqa_scoring"/>
            <field name="implied_ids" eval="[(4, ref('group_caqa_score_reviewer'))]"/>
            <field name="comment">Can act as a Moderator to resolve score variances.</field>
        </record>

        <!-- Manager Group -->
        <record id="group_caqa_score_manager" model="res.groups">
            <field name="name">Accreditation Manager</field>
            <field name="category_id" ref="module_category_caqa_scoring"/>
            <field name="implied_ids" eval="[(4, ref('group_caqa_score_lead_reviewer'))]"/>
            <field name="comment">Can setup rubrics, generate cycles, and generate frozen snapshots.</field>
        </record>
    </data>
</odoo>
