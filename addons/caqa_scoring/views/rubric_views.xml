<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- caqa.score.rubric List View -->
    <record id="view_caqa_score_rubric_tree" model="ir.ui.view">
        <field name="name">caqa.score.rubric.tree</field>
        <field name="model">caqa.score.rubric</field>
        <field name="arch" type="xml">
            <tree string="Evaluation Rubrics">
                <field name="name"/>
                <field name="code"/>
                <field name="is_default"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- caqa.score.rubric Form View -->
    <record id="view_caqa_score_rubric_form" model="ir.ui.view">
        <field name="name">caqa.score.rubric.form</field>
        <field name="model">caqa.score.rubric</field>
        <field name="arch" type="xml">
            <form string="Evaluation Rubric">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 5-Point Quality Rubric"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="is_default"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rubric Levels">
                            <field name="level_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="value_numeric"/>
                                    <field name="name_en"/>
                                    <field name="name_ar"/>
                                    <field name="description"/>
                                    <field name="is_default_fail"/>
                                    <field name="color" widget="color"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_caqa_score_rubric" model="ir.actions.act_window">
        <field name="name">Evaluation Rubrics</field>
        <field name="res_model">caqa.score.rubric</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Evaluation Rubric.
            </p>
            <p>
                Define the grading scales (e.g., 1 to 5) that reviewers will use to grade indicators.
            </p>
        </field>
    </record>
</odoo>
