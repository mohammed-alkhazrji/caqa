<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_caqa_program_course_tree" model="ir.ui.view">
        <field name="name">caqa.program.course.tree</field>
        <field name="model">caqa.program.course</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'active'" decoration-muted="state == 'retired'">
                <field name="program_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="level_no"/>
                <field name="semester_no"/>
                <field name="credit_hours"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_caqa_program_course_search" model="ir.ui.view">
        <field name="name">caqa.program.course.search</field>
        <field name="model">caqa.program.course</field>
        <field name="arch" type="xml">
            <search>
                <field name="program_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="semester_no"/>
                <group expand="0" string="Group By">
                    <filter name="group_program" string="Program" context="{'group_by': 'program_id'}"/>
                    <filter name="group_semester" string="Semester" context="{'group_by': 'semester_no'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_caqa_program_course_form" model="ir.ui.view">
        <field name="name">caqa.program.course.form</field>
        <field name="model">caqa.program.course</field>
        <field name="arch" type="xml">
            <form string="Program Course">
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1><div class="text-muted"><field name="code"/></div></div>
                    <group>
                        <group><field name="program_id"/><field name="level_no"/><field name="semester_no"/></group>
                        <group><field name="credit_hours"/><field name="contact_hours"/><field name="state" widget="badge"/><field name="active"/></group>
                    </group>
                    <notebook>
                        <page string="Learning Outcomes"><field name="learning_outcomes" widget="html"/></page>
                        <page string="Syllabus Summary"><field name="syllabus_summary" widget="html"/></page>
                        <page string="Prerequisites"><field name="prerequisite_course_ids" widget="many2many_tags"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_caqa_program_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">caqa.program.course</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_caqa_program_course_search"/>
    </record>
</odoo>
