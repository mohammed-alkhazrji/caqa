<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_caqa_program_supervisor_own" model="ir.rule">
        <field name="name">Program - Supervisor Own Institution</field>
        <field name="model_id" ref="model_caqa_program"/>
        <field name="groups" eval="[(4, ref('caqa_security.group_caqa_institution_supervisor'))]"/>
        <field name="domain_force">[('institution_id', 'in', user.caqa_institution_ids.ids)]</field>
    </record>

    <record id="rule_caqa_program_user_own" model="ir.rule">
        <field name="name">Program - User Own Institution</field>
        <field name="model_id" ref="model_caqa_program"/>
