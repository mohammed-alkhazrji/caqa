    </record>

    <record id="rule_caqa_program_admin_full_access" model="ir.rule">
        <field name="name">Program - System Administrator Full Access</field>
        <field name="model_id" ref="model_caqa_program"/>
        <field name="groups" eval="[(4, ref('caqa_security.group_caqa_system_administrator'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

