<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_caqa_review_assignment_reviewer_own" model="ir.rule">
        <field name="name">Review assignment - reviewer own</field>
        <field name="model_id" ref="model_caqa_review_assignment"/>
        <field name="domain_force">['|', ('reviewer_id', '=', user.id), ('application_id.institution_id.member_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('caqa_security.group_caqa_reviewer')), (4, ref('caqa_security.group_caqa_senior_reviewer')), (4, ref('caqa_security.group_caqa_institution_supervisor')), (4, ref('caqa_security.group_caqa_institution_user'))]"/>
    </record>
    <record id="rule_caqa_review_assignment_admin_full_access" model="ir.rule">
        <field name="name">Review assignment - admin full access</field>
        <field name="model_id" ref="model_caqa_review_assignment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('caqa_security.group_caqa_system_administrator'))]"/>
    </record>
</odoo>
